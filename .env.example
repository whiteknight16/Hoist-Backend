# Pullvid backend configuration. Copy to `.env` and adjust as needed.
# All variables are optional; the defaults below match the application defaults.

# Host/port for uvicorn.
PULLVID_HOST=0.0.0.0
PULLVID_PORT=8000

# Comma-separated list of allowed CORS origins (the frontend origin).
PULLVID_CORS_ORIGINS=http://localhost:3000

# Directory where per-request downloads are temporarily written.
PULLVID_DOWNLOAD_DIR=./downloads

# Optional path to a Netscape-format cookies.txt (required for most Instagram content).
PULLVID_COOKIES_FILE=

# Reject videos longer than this many seconds (default 2h).
PULLVID_MAX_DURATION_SECONDS=7200

# On startup, delete temp files/dirs older than this many seconds (default 1h).
PULLVID_CLEANUP_AFTER_SECONDS=3600
